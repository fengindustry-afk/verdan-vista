# Supabase connection — copy to `.env` and fill in (Dashboard → Project Settings → API).
# Safe to expose in the client build ONLY when Row-Level Security is enabled.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Sentry error tracking — optional (https://sentry.io)
# Create a project, copy DSN from Settings → Client Keys (DSN)
# Leave empty to disable error tracking
VITE_SENTRY_DSN=

# ── dMRV sensor ingestion (api/ingest/sensor.js) — SERVER-SIDE ONLY ──────────
# These are read by the Vercel serverless ingest endpoint, NOT the browser bundle.
# Never prefix them with VITE_ (that would leak the service key to the client).
# SUPABASE_SERVICE_KEY: service-role key (bypasses RLS) — Dashboard → API → service_role.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
# JSON map of registered device id -> hex HMAC secret (openssl rand -hex 32).
SENSOR_DEVICE_SECRETS={"pyro-reactor-01":"REPLACE-WITH-HEX-SECRET"}
