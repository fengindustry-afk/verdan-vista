#!/bin/sh
# Runs the pre-push checks before every `git push`.
# Enable once with:  git config core.hooksPath .githooks
echo "Running pre-push checks..."
node scripts/prepush-check.mjs
status=$?
if [ $status -ne 0 ]; then
  echo "Push aborted. To bypass in an emergency: git push --no-verify"
fi
exit $status
