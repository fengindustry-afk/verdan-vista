# Copy to .env (or export these) before running.

# Which engine to use: paddle (default, CPU) | tesseract | qwen (GPU stub)
OCR_BACKEND=paddle

# Browser origins allowed to call this service. Add your app's dev URL(s).
# Use "*" only for quick local testing.
OCR_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173

# Reject uploads larger than this (bytes). App already compresses to <200KB.
OCR_MAX_BYTES=8388608

# Only for OCR_BACKEND=qwen. Two modes, auto-selected by whether QWEN_API_KEY is set.
#
# Mode A — self-hosted Ollama/vLLM on a GPU box (no API key):
# QWEN_ENDPOINT=http://192.168.1.50:11434
# QWEN_MODEL=qwen2.5vl     # Ollama model tag (default when no key: qwen2.5vl)
#
# Mode B — managed provider, OpenAI-compatible (set a key; provider-agnostic).
# QWEN_ENDPOINT is the provider's base URL; keep the key OUT of git.
#   OpenRouter: https://openrouter.ai/api/v1   model: qwen/qwen2.5-vl-7b-instruct
#   DashScope:  https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_ENDPOINT=https://openrouter.ai/api/v1
# QWEN_API_KEY=sk-...      # presence of this switches to OpenAI-compatible mode
# QWEN_MODEL=qwen/qwen2.5-vl-7b-instruct   # default in key mode: qwen2.5-vl-7b-instruct
# Managed mode SENDS EACH IMAGE TO A THIRD PARTY — required opt-in (data egress).
# Prefer paddle/self-hosted for tax receipts & compliance data. See README.
# QWEN_ALLOW_MANAGED=true
#
# QWEN_TIMEOUT=120         # seconds to wait for a response (default: 120)
